# Default MAC address for /wake endpoint
DEFAULT_MAC="AA:BB:CC:DD:EE:FF" # Replace with your device's MAC address

# API Key(s) for authentication (optional for backward compatibility)
# Provide a single key or comma-separated list for multiple keys
# Example: API_KEY="my-secret-key" or API_KEY="key1,key2,key3"
# If not set, API is accessible without authentication (not recommended for production)
API_KEY=""

# Rate limiting configuration (requests per window in seconds)
# Default: 5 requests per 60 seconds
RATE_LIMIT_REQUESTS="5"
RATE_LIMIT_WINDOW_SECONDS="60"

# Devices registry file path (JSON)
# Stores named devices for wake-by-name functionality
DEVICES_FILE="devices.json"

# Broadcast IP address for Wake-on-LAN packets (optional)
# If not set, uses the system default (usually 255.255.255.255)
# For subnet broadcast, use your network's broadcast address, e.g., 192.168.1.255
# BROADCAST_IP="255.255.255.255"

# WoL Retry configuration
# Number of times to retry sending WoL packet if it fails (default: 3)
WOL_RETRIES="3"
# Delay between retries in seconds (default: 0.5)
WOL_RETRY_DELAY="0.5"

# Logging configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL="INFO"
# Optional log file path (if not set, logs only to stdout)
# LOG_FILE="/var/log/wol-api.log"

# Server configuration
# Host address to bind (default: 0.0.0.0)
HOST="0.0.0.0"
# Port to bind (default: 8080)
PORT="8080"
