DEFAULT_MAC="xx:xx:xx:xx:xx:xx" # Replace with your PC's MAC address

# Database
DB_URL=sqlite+aiosqlite:///./wakeonlan.db

# API Key (optional: initial admin key to be auto-created on startup)
API_KEY_INITIAL=
API_KEY_NAME="Initial Admin Key"

# Rate Limiting (strings like '60/minute')
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_PER_KEY=true
RATE_LIMIT_WAKE=10/minute
RATE_LIMIT_HEALTH=60/minute

# Webhook Delivery
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BASE_DELAY=1.0
WEBHOOK_RETRY_MAX_DELAY=60.0
WEBHOOK_TIMEOUT=10.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60.0

# MQTT (optional, set MQTT_BROKER to enable)
MQTT_BROKER=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=wol
MQTT_KEEPALIVE=60
MQTT_RECONNECT_DELAY=5
FEATURE_MQTT_ENABLED=false

# Device Status Checking
STATUS_PING_TIMEOUT=1.0
STATUS_PING_COUNT=1
STATUS_ARP_ENABLED=true
STATUS_CACHE_TTL=5

# Server-Sent Events (SSE)
SSE_HEARTBEAT_INTERVAL=15
SSE_MAX_QUEUE_SIZE=1000
FEATURE_SSE_ENABLED=true

# Feature Flags
FEATURE_WEBHOOKS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or console
LOG_DEST=stdout  # stdout or file
LOG_FILE=
