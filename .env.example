# Default MAC address for /wake endpoint
DEFAULT_MAC="AA:BB:CC:DD:EE:FF" # Replace with your device's MAC address

# API Key(s) for authentication (optional for backward compatibility)
# Provide a single key or comma-separated list for multiple keys
# Example: API_KEY="my-secret-key" or API_KEY="key1,key2,key3"
# If not set, API is accessible without authentication (not recommended for production)
API_KEY=""

# Rate limiting configuration (requests per window in seconds)
# Default: 5 requests per 60 seconds
RATE_LIMIT_REQUESTS="5"
RATE_LIMIT_WINDOW_SECONDS="60"
